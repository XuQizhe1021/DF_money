APP_NAME=delta-ammo-analyzer
ENVIRONMENT=development
DEBUG=false
TESTING=false
HOST=127.0.0.1
PORT=5000
DB_PATH=database/app.db
API_BASE_URL=https://df-api.apifox.cn
API_AMMO_ENDPOINT=/api/ammo/prices
REQUEST_TIMEOUT_SECONDS=8
REQUEST_RETRIES=3
REQUEST_RETRY_BACKOFF_SECONDS=1.5
FETCH_INTERVAL_MINUTES=60
SCHEDULER_ENABLED=true
MOCK_ON_FAILURE=true
LOG_LEVEL=INFO
LOG_FILE=database/fetcher.log
